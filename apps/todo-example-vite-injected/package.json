{
  "name": "todo-example-vite-injected",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "prebuild": "pnpm run clean",
    "clean": "rimraf dist",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test:e2e": "playwright test --reporter=list && npm run test:e2e:explicit && npm run test:e2e:pattern",
    "test:e2e:explicit": "playwright test --config playwright.explicit.config.ts --reporter=list",
    "test:e2e:pattern": "playwright test --config playwright.pattern.config.ts --reporter=list"
  },
  "dependencies": {
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@mui/icons-material": "^5.15.15",
    "@mui/material": "^5.15.15",
    "@reduxjs/toolkit": "^2.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.43.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.13.1",
    "@typescript-eslint/parser": "^7.13.1",
    "@vitejs/plugin-react": "^4.3.1",
    "@auto-tracer/plugin-vite-react18": "workspace:*",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "rimraf": "^6.0.1",
    "typescript": "^5.2.2",
    "@auto-tracer/react18": "workspace:*",
    "vite": "^5.3.1"
  }
}
