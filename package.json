{
  "private": true,
  "author": "Carl Ribbegårdh",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "dev": "pnpm -r dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:e2e": "pnpm -r test:e2e",
    "list-packages": "pnpm list --depth 0 --json -r | node ./tools/list-packages.cjs",
    "list-packages-duplicates": "pnpm list --depth 0 --json -r | node ./tools/list-packages-duplicates.cjs",
    "publish-use-trace": "pnpm --filter use-trace publish --no-git-checks",
    "publish-auto-tracer-react18": "pnpm --filter @auto-tracer/react18 publish --tag alpha --no-git-checks --access=public",
    "publish-auto-tracer-inject-react18": "pnpm --filter @auto-tracer/inject-react18 publish --tag alpha --no-git-checks --access=public",
    "publish-auto-tracer-plugin-babel-react18": "pnpm --filter @auto-tracer/plugin-babel-react18 publish --tag alpha --no-git-checks --access=public",
    "publish-auto-tracer-plugin-vite-react18": "pnpm --filter @auto-tracer/plugin-vite-react18 publish --tag alpha --no-git-checks --access=public",
    "publish-suite": "pnpm run publish-auto-tracer-react18 && pnpm run publish-auto-tracer-inject-react18 && pnpm run publish-auto-tracer-plugin-vite-react18"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.3",
    "vitest": "4.0.3"
  }
}
