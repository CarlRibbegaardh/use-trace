{
  "name": "auto-tracer-plugin-vite",
  "version": "0.1.0",
  "description": "Vite plugin for auto-injecting useAutoTracer via unplugin",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "_test": "vitest"
  },
  "dependencies": {
    "auto-tracer-inject-core": "workspace:*",
    "unplugin": "^1.5.0"
  },
  "peerDependencies_later": {
    "auto-tracer": "^0.1.0"
  },
  "peerDependencies": {
    "vite": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "auto-tracer": {
      "optional": false
    },
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "@vitest/coverage-v8": "^4.0.3",
    "typescript": "^5.2.0",
    "vitest": "^4.0.3",
    "vite": "^5.3.1"
  },
  "sideEffects": false
}
