{
  "name": "@auto-tracer/react18",
  "version": "1.0.0-alpha.24",
  "description": "Tracing library to detect rerender causes and state changes",
  "author": "Carl Ribbegårdh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CarlRibbegaardh/use-trace/"
  },
  "bugs": {
    "url": "https://github.com/CarlRibbegaardh/use-trace/issues"
  },
  "homepage": "https://github.com/CarlRibbegaardh/use-trace/",
  "type": "module",
  "dependencies": {
    "deepmerge": "^4.3.1",
    "ramda": "^0.32.0",
    "safe-stable-stringify": "^2.4.3"
  },
  "devDependencies": {
    "@testing-library/react": "^14.3.1",
    "@types/node": "^22.12.0",
    "@types/ramda": "^0.31.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.16.1",
    "@typescript-eslint/parser": "^7.16.1",
    "@vitest/coverage-v8": "^4.0.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-sort-exports": "^0.9.1",
    "flatted": "^3.3.3",
    "jsdom": "^24.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^6.0.1",
    "typescript": "~5.5.3",
    "vite": "^5.3.3",
    "vitest": "^4.0.3"
  },
  "scripts": {
    "build": "tsc && vite build --config vite.config.umd.ts",
    "prebuild": "pnpm run clean",
    "postbuild": "tsc --project ./tests/tsconfig.json --noEmit",
    "clean": "rimraf dist coverage",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:ci": "vitest run --mode ci --coverage"
  },
  "files": [
    "dist",
    "package.json",
    "tsconfig.json",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./dist/index.umd.js": "./dist/index.umd.js",
    "./package.json": "./package.json"
  }
}
